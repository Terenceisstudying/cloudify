{
  "name": "scs-risk-assessment-backend",
  "version": "1.0.0",
  "description": "Backend API for SCS Risk Assessment Tool - Cloud-Native Extension",
  "type": "module",
  "scripts": {
    "start": "vercel dev",
    "dev": "vercel dev",
    "test": "cross-env NODE_ENV=test node --test --test-concurrency=1",
    "test:local": "cross-env NODE_ENV=test node --env-file=.env.test --test --test-concurrency=1",
    "seed:all": "node scripts/seed-all.js",
    "seed:questions": "node scripts/seed-questions.js",
    "generate:synthetic": "node scripts/generate-synthetic-data.js",
    "train:ml": "node scripts/train-anomaly-model.js",
    "lint": "echo 'Linting...'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "isolation-forest": "^0.0.9",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "vercel": "^50.32.5"
  }
}
