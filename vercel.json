{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/**/*.js": {
            "memory": 1024,
            "maxDuration": 15,
            "includeFiles": "api-handlers/**, models/**, lib/**, data/**, src/ml/**, controllers/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/public/$1"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "github": {
        "silent": false,
        "autoJobCancelation": true
    }
}