{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "outputDirectory": "public",
    "functions": {
        "api/**/*.js": {
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "env": {
        "NODE_ENV": "production"
    },
    "github": {
        "silent": false,
        "autoJobCancelation": true
    }
}