{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/**/*.js": {
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/api/admin/(.*)",
            "destination": "/api/admin.js"
        },
        {
            "source": "/api/questions/(.*)",
            "destination": "/api/questions.js"
        },
        {
            "source": "/api/assessments/(.*)",
            "destination": "/api/assessments.js"
        },
        {
            "source": "/api/ml/(.*)",
            "destination": "/api/ml.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "github": {
        "silent": false,
        "autoJobCancelation": true
    }
}