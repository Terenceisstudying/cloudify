# ═══════════════════════════════════════════════════════════
# SCS Risk Assessment Tool - Cloud-Native Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Supabase (Database & Storage) ─────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Authentication ─────────────────────────────────────────
# Generate a random string (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-long-random-string-here-min-32-chars

# ─── Email (Gmail App Password) ──────────────────────────────
# Set up: Gmail → Settings → 2FA → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=PSDCloudify <your-email@gmail.com>

# ─── Database (Supabase Connection Pooler) ───────────────────
# Get from: Supabase → Project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Application ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Vercel (Optional - for CLI deployments) ────────────────
# Get these from Vercel dashboard after linking project
# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-org-id
# VERCEL_PROJECT_ID=your-project-id
